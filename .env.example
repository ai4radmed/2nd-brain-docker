# Copy to .env and customize.
# Verify host UID/GID with: id -u; id -g

UID=1000
GID=1000

# Pin Claude Code version (do not use "latest" — we manage upgrades manually).
# The version is installed via Claude's native installer inside the image
# (matches host install method); container self-updates are disabled
# (compose.yml: DISABLE_AUTOUPDATER=1).
#
# To upgrade: bump this value and run `make build` (or `make sync` to follow
# the host's current version automatically).
CLAUDE_CODE_VERSION=2.1.128

# Host paths (override only if non-default).
# Container always mounts to /home/user/projects/2nd-brain-vault{,-guide} (do not change).
# SB_DATA=${HOME}/projects/2nd-brain-vault
# SB_GUIDE=${HOME}/projects/2nd-brain-vault-guide

# Container gogcli (Option B: privilege-separated). Only required if using
# `make up-gog` / `compose.gog.yml`. Ignored otherwise.
# Set to the passphrase of ~/.config/gogcli-container/ keyring (different from
# the host's gog keyring passphrase). See docs/gogcli-container-setup.md.
# GOG_CONTAINER_KEYRING_PASSWORD=

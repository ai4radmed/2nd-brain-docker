# Copy to .env and customize.
# Verify host UID/GID with: id -u; id -g

UID=1000
GID=1000

# Host path of vault data root (WSL2 ext4 native, Syncthing-synced).
# Container always mounts to /home/user/projects/2nd-brain-vault (do not change).
SB_DATA=${HOME}/projects/2nd-brain-vault

# Host path of public methodology guide (git-managed).
# Container always mounts to /home/user/projects/2nd-brain-vault-guide (do not change).
SB_GUIDE=${HOME}/projects/2nd-brain-vault-guide

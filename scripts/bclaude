#!/usr/bin/env bash
# bclaude — host wrapper to enter the running 2nd-brain-docker daemon.
# Translates host PWD into the container's mount namespace when within the vault.

set -euo pipefail

CONTAINER="sb-claude"
VAULT_HOST="${HOME}/projects/2nd-brain-vault"
VAULT_CONT="/home/user/projects/2nd-brain-vault"

if ! docker inspect -f '{{.State.Running}}' "$CONTAINER" >/dev/null 2>&1; then
    echo "bclaude: container '$CONTAINER' is not running." >&2
    echo "  start it with:  cd ~/projects/2nd-brain-docker && make up" >&2
    exit 1
fi

# If host PWD is inside the vault, mirror the relative path; otherwise land at vault root.
if [[ "$PWD" == "$VAULT_HOST"* ]]; then
    cont_pwd="${VAULT_CONT}${PWD#$VAULT_HOST}"
else
    cont_pwd="$VAULT_CONT"
fi

exec docker exec -it -w "$cont_pwd" "$CONTAINER" claude "$@"
